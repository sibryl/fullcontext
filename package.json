{
  "name": "fullcontext",
  "version": "1.0.5",
  "description": "Prevent LLMs from truncating command output",
  "author": "sibryl",
  "license": "MIT",
  "main": "dist/index.js",
  "bin": {
    "fullcontext": "dist/index.js"
  },
  "files": [
    "dist",
    "!dist/*.test.js",
    "!dist/*.test.d.ts"
  ],
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sibryl/fullcontext.git"
  },
  "bugs": {
    "url": "https://github.com/sibryl/fullcontext/issues"
  },
  "homepage": "https://github.com/sibryl/fullcontext#readme",
  "keywords": [
    "cli",
    "llm",
    "ai",
    "developer-tools",
    "command-line",
    "output",
    "truncation",
    "claude",
    "codex",
    "copilot"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test dist/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3"
  }
}
